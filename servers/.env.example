DB_HOST=127.0.0.1
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=sufra_db

# ─── Redis + NATS (use 127.0.0.1, not localhost) ──────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
NATS_URL=nats://127.0.0.1:4222

# ─── AWS S3 (private bucket) ──────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=sufra-private-s3

# ─── JWT (generate with: openssl rand -hex 64) ────────────────────────────────
JWT_ACCESS_SECRET=replace-with-a-long-random-hex-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-hex-secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * to allow all (local dev only).
CORS_ORIGINS=http://localhost:3000,http://localhost:3010,http://localhost:4000,http://localhost:8081,http://localhost:19006

# ─── AI features (menu import + copywriting) — OpenAI only ────────────────────
# Set OPENAI_API_KEY to enable AI features. With no key, AI endpoints return an
# Arabic "service not configured" message (HTTP 503) instead of failing hard.
OPENAI_API_KEY=your-openai-api-key

OPENAI_VISION_MODEL=gpt-4o-mini

